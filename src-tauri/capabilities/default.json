{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions required by the Tasks application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-badge-count",
    "opener:default",
    "notification:default",
    "deep-link:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/unthink-v2"
        },
        {
          "path": "$APPDATA/unthink-v2/**"
        }
      ]
    }
  ]
}
